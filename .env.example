# Application Environment Variables Example

# Backend Application Configuration
PORT=3000
NODE_ENV=development

# Database Connection (Used by Prisma & NestJS)
# For local development outside Docker, point to localhost.
# For running inside Docker Compose, point to the db host: postgres://postgres:postgres@db:5432/gos_exam_analytics?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gos_exam_analytics?schema=public

# Database Container Configuration (Used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gos_exam_analytics
POSTGRES_PORT=5432

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
